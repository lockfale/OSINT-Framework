{
  "name": "osint-framework",
  "version": "2.0.0",
  "description": "OSINT Framework - Modernized with automated link validation and search",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "api": "node api/server.js",
    "validate-links": "node scripts/validate-links.js",
    "validate-links:cron": "node scripts/validate-links.js --output reports/link-health.json",
    "test": "node --test tests/*.test.js",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.{js,json,css,html}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lockfale/OSINT-Framework.git"
  },
  "author": "Justin Nordine (s0lray)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/lockfale/OSINT-Framework/issues"
  },
  "homepage": "https://osintframework.com",
  "dependencies": {
    "d3": "^7.9.0",
    "fuse.js": "^7.0.0",
    "express": "^4.21.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "axios": "^1.7.9",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "chalk": "^5.3.0",
    "vite": "^5.4.11"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
